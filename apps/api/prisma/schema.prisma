generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum PlaceType {
  PLACE
  ACTIVITY
  DAY_TRIP
  STAY_AREA
  ACCOMMODATION
  FOOD
  TRANSPORT
  CUSTOM
}

enum PlaceStatus {
  PROPOSED
  SHORTLISTED
  APPROVED
  REJECTED
}

enum VoteValue {
  UP
  DOWN
  MAYBE
  MUST_HAVE
}

enum SplitType {
  EQUAL
  CUSTOM
  PERCENTAGE
  SHARES
}

enum SettlementStatus {
  OPEN
  PAID
  CONFIRMED
  CANCELLED
}

enum TravelMode {
  DRIVE
  WALK
  BIKE
  TRANSIT
}

enum PollStatus {
  OPEN
  CLOSED
}

enum ChecklistScope {
  PERSONAL
  SHARED
  EVERYONE
}

enum WeatherSuitability {
  INDOOR
  OUTDOOR
  MIXED
}

enum BudgetPreference {
  BUDGET
  NORMAL
  PREMIUM
}

enum AttendanceStatus {
  GOING
  MAYBE
  NO
}

model User {
  id        String           @id @default(cuid())
  email     String           @unique
  name      String
  travelBudgetPreference BudgetPreference @default(NORMAL)
  foodNotes String?
  accessibilityNotes String?
  defaultCurrency String @default("EUR")
  createdAt DateTime         @default(now())
  credential UserCredential?
  trips     TripMember[]
  places    Place[]
  expenses  Expense[]
  accounts  PaymentAccount[]
  votes     PlaceVote[]
  dayVotes  PlaceDayVote[]
  comments  PlaceComment[]
  splits    ExpenseSplit[]
  pollVotes PollVote[]
  checklistAssignments ChecklistAssignment[]
  checklistCompletions ChecklistCompletion[]
  createdPolls Poll[] @relation("PollCreator")
  createdChecklistItems ChecklistItem[] @relation("ChecklistItemCreator")
  settlementPaymentsFrom SettlementPayment[] @relation("SettlementFromUser")
  settlementPaymentsTo SettlementPayment[] @relation("SettlementToUser")
  markedSettlementPayments SettlementPayment[] @relation("SettlementMarkedBy")
  activityEvents ActivityEvent[] @relation("ActivityActor")
  liveLocations UserLiveLocation[]
}

model UserCredential {
  userId       String   @id
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id            String         @id @default(cuid())
  name          String
  destination   String?
  startsAt      DateTime?
  endsAt        DateTime?
  currency      String         @default("CZK")
  inviteCode    String         @unique @default(cuid())
  createdAt     DateTime       @default(now())
  members       TripMember[]
  places        Place[]
  expenses      Expense[]
  itineraryDays ItineraryDay[]
  routePlans    RoutePlan[]
  polls         Poll[]
  checklistItems ChecklistItem[]
  settlementPayments SettlementPayment[]
  activityEvents ActivityEvent[]
  liveLocations UserLiveLocation[]
}

model TripMember {
  id                  String                     @id @default(cuid())
  tripId              String
  userId              String
  role                TripRole                   @default(MEMBER)
  budgetPreference    BudgetPreference           @default(NORMAL)
  budgetAmount        Decimal?
  joinedAt            DateTime                   @default(now())
  trip                Trip                       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilityWindows TripMemberAvailability[]
  itineraryStops      ItineraryStopParticipant[]

  @@unique([tripId, userId])
}

model TripMemberAvailability {
  id           String     @id @default(cuid())
  tripMemberId String
  startsAt     DateTime
  endsAt       DateTime
  startPlaceId String?
  endPlaceId   String?
  note         String?
  member       TripMember @relation(fields: [tripMemberId], references: [id], onDelete: Cascade)
  startPlace   Place?     @relation("AvailabilityStartPlace", fields: [startPlaceId], references: [id])
  endPlace     Place?     @relation("AvailabilityEndPlace", fields: [endPlaceId], references: [id])
}

model PaymentAccount {
  id              String  @id @default(cuid())
  userId          String
  label           String  @default("Main")
  iban            String?
  domesticAccount String?
  bankCode        String?
  recipientName   String?
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Place {
  id                       String                   @id @default(cuid())
  tripId                   String
  createdById              String
  type                     PlaceType
  status                   PlaceStatus              @default(PROPOSED)
  name                     String
  description              String?
  latitude                 Float
  longitude                Float
  locationLabel            String?
  durationMin              Int?
  estimatedCost            Decimal?
  sourceUrl                String?
  imageUrl                 String?
  weatherSuitability       WeatherSuitability     @default(MIXED)
  accommodationProvider    String?
  accommodationExternalId  String?
  accommodationRating      Float?
  accommodationReviewScore Float?
  accommodationReviewCount Int?
  accommodationCurrency    String?
  accommodationDeepLinkUrl String?
  accommodationStatus      String?
  createdAt                DateTime                 @default(now())
  trip                     Trip                     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy                User                     @relation(fields: [createdById], references: [id])
  votes                    PlaceVote[]
  comments                 PlaceComment[]
  dayVotes                 PlaceDayVote[]
  itineraryStops           ItineraryStop[]
  routeLegsFrom            RouteLeg[]               @relation("RouteLegFrom")
  routeLegsTo              RouteLeg[]               @relation("RouteLegTo")
  baseItineraryDays        ItineraryDay[]            @relation("ItineraryDayBasePlace")
  availabilityStartWindows TripMemberAvailability[] @relation("AvailabilityStartPlace")
  availabilityEndWindows   TripMemberAvailability[] @relation("AvailabilityEndPlace")

  @@unique([tripId, accommodationProvider, accommodationExternalId])
  @@index([tripId, status])
}

model PlaceVote {
  id      String    @id @default(cuid())
  placeId String
  userId  String
  value   VoteValue
  place   Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
}

model PlaceComment {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  body      String
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlaceDayVote {
  id             String       @id @default(cuid())
  placeId        String
  itineraryDayId String
  userId         String
  value          VoteValue
  createdAt      DateTime     @default(now())
  place          Place        @relation(fields: [placeId], references: [id], onDelete: Cascade)
  itineraryDay   ItineraryDay @relation(fields: [itineraryDayId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, itineraryDayId, userId])
}

model ItineraryDay {
  id        String          @id @default(cuid())
  tripId    String
  date      DateTime
  title     String?
  basePlaceId String?
  intensity String          @default("NORMAL")
  rainPlan  String?
  bufferMinutes Int         @default(30)
  locked    Boolean         @default(false)
  createdAt DateTime        @default(now())
  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  basePlace Place?          @relation("ItineraryDayBasePlace", fields: [basePlaceId], references: [id], onDelete: SetNull)
  stops     ItineraryStop[]
  placeVotes PlaceDayVote[]

  @@unique([tripId, date])
}

model ItineraryStop {
  id           String                     @id @default(cuid())
  dayId        String
  placeId      String
  order        Int
  startsAt     DateTime?
  endsAt       DateTime?
  note         String?
  day          ItineraryDay               @relation(fields: [dayId], references: [id], onDelete: Cascade)
  place        Place                      @relation(fields: [placeId], references: [id], onDelete: Cascade)
  participants ItineraryStopParticipant[]
  expenses     Expense[]

  @@unique([dayId, order])
}

model ItineraryStopParticipant {
  id           String        @id @default(cuid())
  stopId       String
  tripMemberId String
  status       AttendanceStatus @default(GOING)
  stop         ItineraryStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  member       TripMember    @relation(fields: [tripMemberId], references: [id], onDelete: Cascade)

  @@unique([stopId, tripMemberId])
}

model UserLiveLocation {
  id             String   @id @default(cuid())
  tripId         String
  userId         String
  latitude       Float
  longitude      Float
  accuracyMeters Int?
  sharedUntil    DateTime?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId, updatedAt])
}

model RoutePlan {
  id        String     @id @default(cuid())
  tripId    String
  name      String
  mode      TravelMode @default(DRIVE)
  startsAt  DateTime?
  endsAt    DateTime?
  locked    Boolean    @default(false)
  createdAt DateTime   @default(now())
  trip      Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  legs      RouteLeg[]
}

model RouteLeg {
  id              String    @id @default(cuid())
  routePlanId     String
  fromPlaceId     String
  toPlaceId       String
  order           Int
  distanceMeters  Int?
  durationSeconds Int?
  encodedPolyline String?
  provider        String?
  routePlan       RoutePlan @relation(fields: [routePlanId], references: [id], onDelete: Cascade)
  fromPlace       Place     @relation("RouteLegFrom", fields: [fromPlaceId], references: [id], onDelete: Cascade)
  toPlace         Place     @relation("RouteLegTo", fields: [toPlaceId], references: [id], onDelete: Cascade)

  @@unique([routePlanId, order])
}

model Expense {
  id              String         @id @default(cuid())
  tripId          String
  paidById        String
  title           String
  category        String         @default("OTHER")
  amount          Decimal
  currency        String         @default("CZK")
  originalAmount  Decimal?
  originalCurrency String?
  exchangeRate    Decimal?
  exchangeDate    DateTime?
  splitType       SplitType      @default(EQUAL)
  itineraryStopId String?
  spentAt         DateTime?
  receiptUrl      String?
  createdAt       DateTime       @default(now())
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidBy          User           @relation(fields: [paidById], references: [id])
  itineraryStop   ItineraryStop? @relation(fields: [itineraryStopId], references: [id], onDelete: SetNull)
  splits          ExpenseSplit[]
}

model SettlementPayment {
  id          String           @id @default(cuid())
  tripId      String
  fromUserId  String
  toUserId    String
  amount      Decimal
  currency    String
  status      SettlementStatus @default(OPEN)
  note        String?
  markedById  String?
  paidAt      DateTime?
  confirmedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  trip        Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  fromUser    User             @relation("SettlementFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User             @relation("SettlementToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  markedBy    User?            @relation("SettlementMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)

  @@unique([tripId, fromUserId, toUserId, currency])
  @@index([tripId, status])
}

model ActivityEvent {
  id         String   @id @default(cuid())
  tripId     String
  actorUserId String?
  type       String
  entityType String?
  entityId   String?
  label      String
  metadata   Json?
  createdAt  DateTime @default(now())
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  actor      User?    @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt])
}

model ExpenseSplit {
  id        String  @id @default(cuid())
  expenseId String
  userId    String
  amount    Decimal
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Poll {
  id        String       @id @default(cuid())
  tripId    String
  createdById String
  question  String
  status    PollStatus   @default(OPEN)
  multiChoice Boolean    @default(false)
  contextDayId String?
  contextPlaceId String?
  createdAt DateTime     @default(now())
  closesAt  DateTime?
  trip      Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User         @relation("PollCreator", fields: [createdById], references: [id])
  options   PollOption[]
}

model PollOption {
  id      String     @id @default(cuid())
  pollId  String
  title   String
  order   Int
  placeId String?
  itineraryDayId String?
  poll    Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes   PollVote[]

  @@unique([pollId, order])
}

model PollVote {
  id        String     @id @default(cuid())
  optionId  String
  userId    String
  createdAt DateTime   @default(now())
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
}

model ChecklistItem {
  id          String         @id @default(cuid())
  tripId      String
  createdById String
  title       String
  note        String?
  scope       ChecklistScope @default(SHARED)
  dueAt       DateTime?
  createdAt   DateTime       @default(now())
  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("ChecklistItemCreator", fields: [createdById], references: [id])
  assignments ChecklistAssignment[]
  completions ChecklistCompletion[]
}

model ChecklistAssignment {
  id       String        @id @default(cuid())
  itemId   String
  userId   String
  item     ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}

model ChecklistCompletion {
  id          String        @id @default(cuid())
  itemId      String
  userId      String
  completedAt DateTime     @default(now())
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}
