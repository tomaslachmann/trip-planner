generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum TripRole { OWNER ADMIN MEMBER GUEST }
enum PlaceType { PLACE ACTIVITY DAY_TRIP STAY_AREA ACCOMMODATION FOOD TRANSPORT CUSTOM }
enum VoteValue { UP DOWN MAYBE MUST_HAVE }
enum SplitType { EQUAL CUSTOM PERCENTAGE SHARES }
enum SettlementStatus { OPEN PAID CANCELLED }

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  trips     TripMember[]
  places    Place[]
  expenses  Expense[]
  accounts  PaymentAccount[]
}

model Trip {
  id          String   @id @default(cuid())
  name        String
  destination String?
  startsAt    DateTime?
  endsAt      DateTime?
  currency    String   @default("CZK")
  inviteCode  String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  members     TripMember[]
  places      Place[]
  expenses    Expense[]
}

model TripMember {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  role      TripRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([tripId, userId])
}

model PaymentAccount {
  id            String @id @default(cuid())
  userId        String
  label         String @default("Main")
  iban          String?
  domesticAccount String?
  bankCode      String?
  recipientName String?
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Place {
  id          String    @id @default(cuid())
  tripId      String
  createdById String
  type        PlaceType
  name        String
  description String?
  latitude    Float
  longitude   Float
  durationMin Int?
  estimatedCost Decimal?
  sourceUrl   String?
  createdAt   DateTime @default(now())
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id])
  votes       PlaceVote[]
  comments    PlaceComment[]
}

model PlaceVote {
  id      String    @id @default(cuid())
  placeId String
  userId  String
  value   VoteValue
  place   Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  @@unique([placeId, userId])
}

model PlaceComment {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  body      String
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Expense {
  id        String    @id @default(cuid())
  tripId    String
  paidById  String
  title     String
  amount    Decimal
  currency  String    @default("CZK")
  splitType SplitType @default(EQUAL)
  createdAt DateTime  @default(now())
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidBy    User      @relation(fields: [paidById], references: [id])
  splits    ExpenseSplit[]
}

model ExpenseSplit {
  id        String  @id @default(cuid())
  expenseId String
  userId    String
  amount    Decimal
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}
