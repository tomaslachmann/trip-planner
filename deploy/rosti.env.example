POSTGRES_DB=trip_planner
POSTGRES_USER=trip_planner
POSTGRES_PASSWORD=change-this-postgres-password

JWT_SECRET=change-this-to-at-least-32-random-characters

API_IMAGE=ghcr.io/tomaslachmann/trip-planner-api:latest
UI_IMAGE=ghcr.io/tomaslachmann/trip-planner-ui:latest

# Same-origin API behind Traefik. Keep UI on /api unless the compose routing changes.
NEXT_PUBLIC_API_URL=/api

# Set this to the public stack/domain with the /api prefix so generated upload URLs are correct.
PUBLIC_API_URL=https://your-domain.example/api

BOOKING_PROVIDER=rapidapi
BOOKING_API_BASE_URL=https://demandapi-sandbox.booking.com/3.1
BOOKING_AFFILIATE_ID=
BOOKING_API_TOKEN=
BOOKING_RAPIDAPI_BASE_URL=https://booking-com15.p.rapidapi.com
BOOKING_RAPIDAPI_HOST=booking-com15.p.rapidapi.com
RAPIDAPI_KEY=

REQUEST_TIMEOUT_MS=120000
ROUTING_OSRM_BASE_URL=https://router.project-osrm.org
ROUTING_PROVIDER=osrm
TRANSIT_PROVIDER=none
TRANSIT_OTP_BASE_URL=

NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=trip-planner/0.1 (https://your-domain.example/contact)
WIKIMEDIA_USER_AGENT=trip-planner/0.1 (https://your-domain.example/contact)
WIKIMEDIA_RATE_LIMIT_PER_MINUTE=200
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_MS=120000
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
